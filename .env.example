# =============================================================================
# Astro Business Stack — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables prefixed with PUBLIC_ are exposed to the browser — NEVER prefix secrets.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Canonical site URL (sitemap, OG images, canonical links)
SITE_URL=https://stack.example.com

# -----------------------------------------------------------------------------
# Docker identity (VPS)
# -----------------------------------------------------------------------------
APP_CONTAINER_NAME=astro-stack-test-app
AUTH_CONTAINER_NAME=astro-stack-test-auth
APP_IMAGE=astro-stack-test
AUTH_IMAGE=astro-stack-test-auth
PORT=4325

# -----------------------------------------------------------------------------
# OAuth gateway (Decap CMS)
# -----------------------------------------------------------------------------
# Public URL where the auth-gateway container is reachable (no trailing slash).
# Must match the callback URL registered in your GitHub OAuth App.
AUTH_GATEWAY_URL=https://stack.example.com
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# -----------------------------------------------------------------------------
# Transactional email (Resend)
# -----------------------------------------------------------------------------
# Required for lead/contact notification emails when integrations are enabled.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Stack Demo <onboarding@resend.dev>
# LEAD_NOTIFICATION_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Analytics (optional — client-side)
# -----------------------------------------------------------------------------
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# PUBLIC_GTM_ID=GTM-XXXXXXX

# -----------------------------------------------------------------------------
# Search engine verification (optional)
# -----------------------------------------------------------------------------
# PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
# PUBLIC_BING_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------------------------------------
# Consent / privacy (recommended for production)
# -----------------------------------------------------------------------------
# PUBLIC_CONSENT_ENABLED=true
# PUBLIC_PRIVACY_POLICY_URL=/privacy

# -----------------------------------------------------------------------------
# Booking (Cal.com) — optional
# -----------------------------------------------------------------------------
# PUBLIC_CAL_LINK=your-team/demo-call
# PUBLIC_CAL_LINK_EN=your-team/demo-call
# PUBLIC_CAL_LINK_ES=your-team/demo-call-es
# PUBLIC_CAL_LINK_CA=your-team/demo-call-ca
# PUBLIC_CAL_LINK_PL=your-team/demo-call-pl

# -----------------------------------------------------------------------------
# CRM (Notion) — optional. If unset, leads go straight to Resend (no dedup).
# -----------------------------------------------------------------------------
# NOTION_API_KEY=ntn_xxx
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_CLIENTS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Analytics (Supabase) — optional. If unset, funnel events are not recorded.
# -----------------------------------------------------------------------------
# SUPABASE_TRACKING_ENABLED=true
# SUPABASE_URL=https://xxx.supabase.co  (base URL only — no /rest/v1/)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# ANALYTICS_SALT=64-char-random-hex
# ANALYTICS_ENV=development
# ANALYTICS_SITE_ID=stack.andreuog.com  # optional; defaults to SITE_URL hostname
# Per-repo profile: src/config/analytics.profile.ts (synced to Supabase on ingest/dashboard load)

# -----------------------------------------------------------------------------
# Admin metrics dashboard (/admin/metrics)
# -----------------------------------------------------------------------------
# Off in production builds unless true. Local `pnpm dev` is always allowed.
# ADMIN_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Demo video (homepage)
# -----------------------------------------------------------------------------
# MP4 path (/demo/LinkedIn-stack.mp4) or YouTube URL / video ID. Poster: public/demo/tumbnail.png
# PUBLIC_DEMO_VIDEO_URL=

# -----------------------------------------------------------------------------
# Live demo sandbox (homepage — isolated demo Supabase + Notion)
# -----------------------------------------------------------------------------
# PUBLIC_LIVE_DEMO_ENABLED=true
# DEMO_SUPABASE_URL=https://xxx.supabase.co  (base URL only — no /rest/v1/)
# DEMO_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# DEMO_NOTION_API_KEY=ntn_xxx
# DEMO_NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEMO_MAX_RUNS_PER_HOUR=5
# DEMO_GLOBAL_MAX_RUNS_PER_HOUR=60

# -----------------------------------------------------------------------------
# Rate limiting (Supabase-backed; run SQL migrations below)
# -----------------------------------------------------------------------------
# RATE_LIMIT_SALT=64-char-random-hex  # falls back to ANALYTICS_SALT if unset
# API_LEADS_MAX_PER_HOUR=10
# API_LEADS_CONFIRM_MAX_PER_HOUR=10
# API_CALENDAR_VIEWED_MAX_PER_HOUR=20
# API_ANALYTICS_INTERACTION_MAX_PER_HOUR=30

# -----------------------------------------------------------------------------
# Live demo CAPTCHA (Cloudflare Turnstile — off by default)
# -----------------------------------------------------------------------------
# PUBLIC_DEMO_CAPTCHA_ENABLED=false
# PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
