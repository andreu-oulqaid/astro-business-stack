---
import { getCollection } from 'astro:content';
import { locales, defaultLocale, type Locale } from '@/i18n/config';
import { routes, type RouteId } from '@/i18n/routes';
import { pillarFilesystemSegmentFromServicesSlugTail } from '@/i18n/helpers';

const FILESYSTEM_PILLAR_SEGMENTS = new Set(['web', 'automation', 'full-system']);

function stripServicesBase(path: string, locale: Locale): string {
  const bases = [...new Set([routes.services[locale], routes.services[defaultLocale]])];
  for (const base of bases) {
    if (!base) continue;
    if (path === base) return '';
    if (path.startsWith(`${base}/`)) return path.slice(base.length + 1);
  }
  return path;
}

export async function getStaticPaths() {
  const pillarRouteIds: RouteId[] = ['serviceWeb', 'serviceAutomation', 'serviceFullSystem'];
  const paths: Array<{ params: { lang: string; services: string } }> = [];

  const enServicesBase = routes.services[defaultLocale];
  const filesystemPillarTails = new Set(['web', 'automation', 'full-system']);

  for (const lang of locales) {
    if (lang === defaultLocale) continue;

    const translatedBase = routes.services[lang];
    paths.push({ params: { lang, services: translatedBase } });

    for (const routeId of pillarRouteIds) {
      paths.push({ params: { lang, services: routes[routeId][lang] } });
    }

    for (const routeId of pillarRouteIds) {
      const full = routes[routeId][lang];
      const tail = full.startsWith(`${translatedBase}/`) ? full.slice(translatedBase.length + 1) : '';
      if (!tail || filesystemPillarTails.has(tail)) continue;
      paths.push({ params: { lang, services: `${enServicesBase}/${tail}` } });
    }

    const posts = await getCollection('services', ({ data }) => {
      return data.locale === lang && (import.meta.env.PROD ? data.draft !== true : true);
    });

    const pillarSlugs = new Set(['web', 'automation', 'full-system']);

    for (const post of posts) {
      const slug = post.id.replace(`${lang}/`, '');
      if (pillarSlugs.has(slug)) continue;
      paths.push({
        params: { lang, services: `${translatedBase}/${slug}` },
      });
    }
  }

  return paths;
}

const { lang, services } = Astro.params;
const locale = lang as Locale;
const extra = stripServicesBase(services ?? '', locale);

const portfolioOut = routes.portfolio[defaultLocale];

let target: string;
if (!extra) {
  target = `/${lang}/services`;
} else if (FILESYSTEM_PILLAR_SEGMENTS.has(extra)) {
  target = `/${lang}/services/${extra}`;
} else {
  const pillarSeg = pillarFilesystemSegmentFromServicesSlugTail(extra, locale);
  target = pillarSeg ? `/${lang}/services/${pillarSeg}` : `/${lang}/${portfolioOut}/${extra}`;
}

return Astro.redirect(target, 301);
---
