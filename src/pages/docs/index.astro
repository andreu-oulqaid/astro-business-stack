---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/landing/Navbar.astro';
import LandingFooter from '@/components/landing/LandingFooter.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getCollection } from 'astro:content';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath, useTranslations } from '@/i18n/index';

const locale = defaultLocale;
const t = useTranslations(locale);
const docsBase = getLocalizedPath('docs', locale);

const guides = (await getCollection('docs', ({ data }) => {
  return data.locale === locale && (import.meta.env.PROD ? data.draft !== true : true);
})).sort((a, b) => a.data.order - b.data.order || b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const getGuideUrl = (postId: string) => {
  const slug = postId.replace(`${locale}/`, '');
  return `${docsBase}/${slug}`;
};
---

<BaseLayout title={t('docs.title')} description={t('docs.description')} routeId="docs">
  <Navbar slot="header" />

  <section class="border-b border-border bg-background-secondary py-16">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <h1 class="font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl">
        {t('docs.title')}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-foreground-muted">{t('docs.description')}</p>
      <a
        href="/#process"
        class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 hover:text-brand-500 dark:text-brand-400"
      >
        <Icon name="arrow-left" size="sm" />
        Homepage pipeline
      </a>
    </div>
  </section>

  <section class="bg-background py-16">
    <div class="mx-auto max-w-6xl px-6">
      {guides.length > 0 ? (
        <>
          <div class="mb-8 flex flex-wrap items-center gap-2">
            <span class="text-sm font-medium text-foreground-secondary">{t('docs.filterLabel')}:</span>
            <button type="button" data-filter-btn data-filter="all" class="docs-filter-btn is-active">{t('docs.filterAll')}</button>
            <button type="button" data-filter-btn data-filter="deploy" class="docs-filter-btn">{t('docs.filter.deploy')}</button>
            <button type="button" data-filter-btn data-filter="capabilities" class="docs-filter-btn">{t('docs.filter.capabilities')}</button>
          </div>

          <div id="docs-grid" class="grid gap-6 md:grid-cols-2">
            {guides.map((guide) => (
              <BlogCard
                title={guide.data.title}
                description={guide.data.description}
                href={getGuideUrl(guide.id)}
                tags={guide.data.tags}
                image={guide.data.image}
                data-category={guide.data.category}
              />
            ))}
          </div>
        </>
      ) : (
        <p class="text-center text-foreground-muted">{t('blog.noPosts')}</p>
      )}
    </div>
  </section>

  <LandingFooter slot="footer" />
</BaseLayout>

<script>
  function initDocsFilters() {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('#docs-grid article'));
    if (!buttons.length || !cards.length) return;

    function applyFilter(filter: string) {
      cards.forEach((card) => {
        const category = card.getAttribute('data-category') || 'deploy';
        const visible = filter === 'all' || category === filter;
        card.classList.toggle('hidden', !visible);
      });
      buttons.forEach((btn) => btn.classList.toggle('is-active', btn.dataset.filter === filter));
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => applyFilter(button.dataset.filter || 'all'));
    });
  }

  initDocsFilters();
  document.addEventListener('astro:page-load', initDocsFilters);
</script>

<style>
  .docs-filter-btn {
    border: 1px solid var(--border);
    background: var(--background);
    color: var(--foreground-muted);
    border-radius: 9999px;
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1rem;
    transition: all 150ms ease;
  }
  .docs-filter-btn:hover {
    border-color: color-mix(in oklab, var(--brand-500) 40%, var(--border));
    color: var(--foreground);
  }
  .docs-filter-btn.is-active {
    border-color: var(--brand-500);
    background: color-mix(in oklab, var(--brand-500) 12%, var(--background));
    color: var(--foreground);
  }
</style>
