---
interface Props {
  projectName: string;
  projectId: string;
  envLabel: string;
  rangeLabel: string;
  usedRpc: boolean;
  fallbackWarning: string | null;
}

const { projectName, projectId, envLabel, rangeLabel, usedRpc, fallbackWarning } = Astro.props;
const statusTitle = usedRpc
  ? 'Aggregates served from database RPC'
  : fallbackWarning ?? 'Using client-side fallback aggregates';
const statusTone = usedRpc ? 'bg-emerald-500' : 'bg-amber-500';
---

<header class="space-y-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="font-display text-3xl font-bold tracking-tight text-foreground">{projectName}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span class="rounded-full border border-border bg-secondary px-3 py-1 text-xs font-medium text-foreground">
          {envLabel}
        </span>
        <span class="rounded-full border border-border bg-secondary px-3 py-1 text-xs font-medium text-foreground">
          {rangeLabel}
        </span>
        <span class="rounded-full border border-border bg-secondary px-3 py-1 font-mono text-xs text-foreground-muted">
          {projectId}
        </span>
      </div>
    </div>

    <div class="flex items-center gap-2 text-xs text-foreground-muted" title={statusTitle}>
      <span class:list={['inline-block h-2 w-2 rounded-full', statusTone]} />
      <span>{usedRpc ? 'Live aggregates' : 'Fallback mode'}</span>
    </div>
  </div>
</header>
