---
import { metricsEnvHref, type MetricsEnvParam } from '@/lib/metricsEnvParams';

interface Props {
  range: '7d' | '30d';
  env: MetricsEnvParam;
}

const { range, env } = Astro.props;

function rangeHref(nextRange: '7d' | '30d'): string {
  return metricsEnvHref('/admin/metrics', { range: nextRange, env });
}

function envHref(nextEnv: MetricsEnvParam): string {
  return metricsEnvHref('/admin/metrics', { range, env: nextEnv });
}
---

<div class="flex flex-col items-stretch gap-2 sm:items-end">
  <div class="inline-flex rounded-lg border border-border bg-secondary p-1 text-sm">
    <a
      href={rangeHref('7d')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        range === '7d' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      Last 7 days
    </a>
    <a
      href={rangeHref('30d')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        range === '30d' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      Last 30 days
    </a>
  </div>
  <div class="inline-flex flex-wrap justify-end gap-1 rounded-lg border border-border bg-secondary p-1 text-sm">
    <a
      href={envHref('deploy')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        env === 'deploy' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      This deploy
    </a>
    <a
      href={envHref('all')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        env === 'all' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      All envs
    </a>
    <a
      href={envHref('development')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        env === 'development' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      Development
    </a>
    <a
      href={envHref('production')}
      class:list={[
        'rounded-md px-3 py-1.5 transition',
        env === 'production' ? 'bg-foreground text-background' : 'text-foreground-muted hover:text-foreground',
      ]}
    >
      Production
    </a>
  </div>
</div>
