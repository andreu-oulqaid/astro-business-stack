---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span
  class:list={[
    'flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border bg-background-secondary text-brand-500',
    className,
  ]}
>
  <Icon name="code" size="sm" />
</span>
