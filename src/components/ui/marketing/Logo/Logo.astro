---
/**
 * Logo Component
 *
 * Logomark: public/favicon.svg (generate PNG/ICO variants from the same source).
 * Full logo: src/assets/branding/logo-full*.svg
 */
import siteConfig from '@/config/site.config';

import logoFull from '@/assets/branding/logo-full.svg';
import logoFullDark from '@/assets/branding/logo-full-dark.svg';

interface Props {
  /** Size preset */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force dark mode logo (for dark backgrounds) */
  forceDark?: boolean;
  /** Use full logo instead of logomark */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
}

const {
  size = 'md',
  forceDark = false,
  variant = 'logomark',
  class: className,
} = Astro.props;

const faviconSrc = siteConfig.branding.favicon.svg;
const lightLogo = variant === 'full' ? logoFull : null;
const darkLogo = variant === 'full' ? logoFullDark : null;

const sizeClasses: Record<string, string> = {
  sm: 'h-5 w-5',
  md: 'h-6 w-6',
  lg: 'h-8 w-8',
  xl: 'h-12 w-12',
  '2xl': 'h-28 w-28',
};

const sizeClass = sizeClasses[size] || sizeClasses.md;
---

<span class:list={['inline-block', className]}>
  {
    variant === 'logomark' ? (
      <img
        src={faviconSrc}
        alt={siteConfig.branding.logo.alt}
        class:list={[sizeClass, 'rounded-sm']}
      />
    ) : forceDark ? (
      <img src={darkLogo!.src} alt={siteConfig.branding.logo.alt} class:list={[sizeClass]} />
    ) : (
      <Fragment>
        <img
          src={lightLogo!.src}
          alt={siteConfig.branding.logo.alt}
          class:list={[sizeClass, 'block dark:hidden']}
        />
        <img
          src={darkLogo!.src}
          alt=""
          class:list={[sizeClass, 'hidden dark:block']}
          aria-hidden="true"
        />
      </Fragment>
    )
  }
</span>
