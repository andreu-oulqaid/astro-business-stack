---
/**
 * Language Switcher Component
 * Allows users to switch between available locales while maintaining the current page
 *
 * This component uses the route-aware switchLocale() helper to generate
 * correct translated URLs when switching languages.
 *
 * Example:
 * - On /about → switching to ES → /es/sobre-nosotros
 * - On /es/sobre-nosotros → switching to FR → /fr/a-propos
 */

import { locales, type Locale, getLocaleFromPath } from '@/i18n/config';
import { switchLocale } from '@/i18n/helpers';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const currentPath = Astro.url.pathname;
const currentLocale = getLocaleFromPath(currentPath);
const pickerId = `language-switcher-${Math.random().toString(36).slice(2, 10)}`;

const localeNativeNames: Record<Locale, string> = {
  ca: 'Català',
  es: 'Castellano',
  en: 'English',
  pl: 'Polski',
};

const localeCodes: Record<Locale, string> = {
  ca: 'CA',
  es: 'ES',
  en: 'EN',
  pl: 'PL',
};
---

<div
  class:list={['relative inline-block text-center', className]}
  data-preferred-locale-cookie="preferred_locale"
>
  <button
    type="button"
    data-language-switcher-trigger={pickerId}
    class="group flex w-full min-w-[7.5rem] items-center justify-center gap-2 rounded-md border border-border bg-background px-3 py-2 font-display text-sm text-foreground transition-colors duration-300 hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    aria-expanded="false"
    aria-haspopup="true"
    aria-label={`Current language: ${localeNativeNames[currentLocale]}`}
  >
    <span class="hidden sm:inline">{localeNativeNames[currentLocale]}</span>
    <span class="sm:hidden">{localeCodes[currentLocale]}</span>
    <svg
      class="h-4 w-4 transition-transform duration-300 group-aria-expanded:rotate-180"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
        clip-rule="evenodd"></path>
    </svg>
  </button>

  <div
    data-language-switcher-menu={pickerId}
    class="absolute left-1/2 z-50 mt-2 hidden w-44 origin-top -translate-x-1/2 rounded-md border border-border bg-background shadow-lg focus:outline-none"
    role="menu"
    aria-orientation="vertical"
    aria-label="Language options"
  >
    <div class="py-1" role="none">
      {
        locales.map((locale) => {
          const isActive = locale === currentLocale;
          const href = switchLocale(currentPath, locale);

          return (
            <a
              href={href}
              class:list={[
                'block px-4 py-2 text-center font-display text-sm transition-colors duration-300',
                isActive
                  ? 'bg-secondary/80 text-brand-600 dark:text-brand-400 font-medium'
                  : 'text-foreground hover:bg-secondary/50 hover:text-foreground',
              ]}
              role="menuitem"
              aria-current={isActive ? 'page' : undefined}
              aria-label={`Switch language to ${localeNativeNames[locale]}`}
            >
              <span class="hidden sm:inline">{localeNativeNames[locale]}</span>
              <span class="sm:hidden">{localeCodes[locale]}</span>
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  const PREFERRED_LOCALE_MAX_AGE = 60 * 60 * 24 * 365;

  function setPreferredLocaleCookie(name: string, locale: string) {
    document.cookie = `${name}=${encodeURIComponent(locale)};path=/;max-age=${PREFERRED_LOCALE_MAX_AGE};SameSite=Lax`;
  }

  function initLanguageSwitchers() {
    document.querySelectorAll('[data-language-switcher-trigger]').forEach((btn) => {
      if (!(btn instanceof HTMLButtonElement)) return;
      if (btn.dataset.languageSwitcherBound === '1') return;

      const key = btn.dataset.languageSwitcherTrigger;
      if (!key) return;

      const menu = document.querySelector(`[data-language-switcher-menu="${key}"]`);
      if (!(menu instanceof HTMLElement)) return;

      const root = btn.closest('[data-preferred-locale-cookie]');
      const cookieName =
        root instanceof HTMLElement ? root.dataset.preferredLocaleCookie ?? 'preferred_locale' : 'preferred_locale';

      btn.dataset.languageSwitcherBound = '1';

      const closeMenu = () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      };

      menu.querySelectorAll('a[role="menuitem"]').forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        if (link.dataset.localeCookieBound === '1') return;
        link.dataset.localeCookieBound = '1';

        link.addEventListener('click', () => {
          const href = link.getAttribute('href') ?? '';
          const segments = href.split('/').filter(Boolean);
          const first = segments[0];
          const locale =
            first === 'es' || first === 'ca' || first === 'pl' ? first : 'en';
          setPreferredLocaleCookie(cookieName, locale);
        });
      });

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const willOpen = menu.classList.contains('hidden');
        menu.classList.toggle('hidden', !willOpen);
        btn.setAttribute('aria-expanded', String(willOpen));
      });

      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Node)) return;
        if (!btn.contains(target) && !menu.contains(target)) {
          closeMenu();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    });
  }

  initLanguageSwitchers();
  document.addEventListener('astro:page-load', initLanguageSwitchers);
</script>
