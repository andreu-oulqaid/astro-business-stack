---
/**
 * LandingFooter Component (i18n-aware)
 * Footer for landing pages with translations
 */
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { type Locale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const links = [
  { label: t('footer.links.documentation'), href: `${siteConfig.github.url}#readme` },
  { label: t('footer.links.github'), href: siteConfig.github.profile },
  { label: t('footer.links.license'), href: `${siteConfig.github.url}/blob/main/LICENSE` },
  { label: t('footer.links.privacy'), href: getLocalizedPath('privacy', locale) },
];
---

<footer class="border-t border-border bg-background-secondary py-12">
  <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <!-- Logo & Attribution -->
    <div class="flex flex-col gap-2">
      <a href={getLocalizedPath('home', locale)} class="flex items-center gap-2">
        <span class="flex h-7 w-7 items-center justify-center rounded-md border border-border bg-background text-brand-500">
          <Icon name="code" size="sm" />
        </span>
        <span class="font-display text-lg font-semibold tracking-tight text-foreground">{t('site.name')}</span>
      </a>
    </div>

    <!-- Links -->
    <nav class="flex gap-8 text-sm text-foreground-muted font-medium">
      {links.map((link) => (
        <a
          href={link.href}
          class="hover:text-foreground transition-colors"
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
