---
interface Props {
  title: string;
  legacyLabel: string;
  legacyScore: number;
  legacyCaption: string;
  ourLabel: string;
  ourScore: number;
  ourCaption: string;
  disclaimerLead: string;
  lighthouseLinkLabel: string;
  disclaimerTrail: string;
  lighthouseHref?: string;
}

const {
  title,
  legacyLabel,
  legacyScore,
  ourLabel,
  ourScore,
  legacyCaption,
  ourCaption,
  disclaimerLead,
  lighthouseLinkLabel,
  disclaimerTrail,
  lighthouseHref = '#',
} = Astro.props;

function dashOffset(score: number) {
  const circumference = 339.292;
  const pct = Math.min(100, Math.max(0, score)) / 100;
  return circumference * (1 - pct);
}

const legacyDash = dashOffset(legacyScore);
const ourDash = dashOffset(ourScore);
---

<section class="border-border border-y bg-background-secondary py-14 md:py-18" aria-labelledby="smackdown-heading">
  <div class="mx-auto max-w-6xl px-6">
    <h2 id="smackdown-heading" class="font-display mb-10 text-center text-2xl font-bold text-foreground md:text-3xl">
      {title}
    </h2>
    <!-- overflow-visible avoids stroke/glow cropping from layout; no SVG drop-shadow (clips as a square on some stacks) -->
    <div class="grid gap-10 overflow-visible md:grid-cols-2 md:gap-12">
      <div class="flex flex-col items-center overflow-visible text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-foreground-muted">{legacyLabel}</p>
        <div class="relative overflow-visible p-1">
          <svg class="h-28 w-28 overflow-visible sm:h-32 sm:w-32" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="54" fill="none" stroke="currentColor" stroke-width="8" class="text-border" />
            <circle
              cx="60"
              cy="60"
              r="54"
              fill="none"
              stroke="currentColor"
              stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray="339.292"
              stroke-dashoffset={legacyDash}
              class="text-orange-600 dark:text-orange-500"
              style="transform: rotate(-90deg); transform-origin: center;"
            />
            <text
              x="60"
              y="60"
              text-anchor="middle"
              dominant-baseline="central"
              class="fill-current text-2xl font-bold text-orange-600 dark:text-orange-400"
              style="font-family: system-ui, sans-serif;"
            >
              {legacyScore}
            </text>
          </svg>
        </div>
        <p class="mt-4 max-w-sm text-sm text-foreground-muted">{legacyCaption}</p>
      </div>
      <div class="flex flex-col items-center overflow-visible text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-foreground-muted">{ourLabel}</p>
        <div class="relative flex flex-col items-center overflow-visible p-1">
          <svg class="h-28 w-28 overflow-visible sm:h-32 sm:w-32" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="54" fill="none" stroke="currentColor" stroke-width="8" class="text-border" />
            <circle
              cx="60"
              cy="60"
              r="54"
              fill="none"
              stroke="currentColor"
              stroke-width="8"
              stroke-linecap="round"
              stroke-dasharray="339.292"
              stroke-dashoffset={ourDash}
              class="text-emerald-400"
              style="transform: rotate(-90deg); transform-origin: center;"
            />
            <text
              x="60"
              y="60"
              text-anchor="middle"
              dominant-baseline="central"
              class="fill-current text-2xl font-bold text-emerald-400"
              style="font-family: system-ui, sans-serif;"
            >
              {ourScore}
            </text>
          </svg>
        </div>
        <p class="mt-4 max-w-sm text-sm text-foreground-muted">{ourCaption}</p>
      </div>
    </div>
    <p class="mx-auto mt-10 max-w-3xl text-center text-xs leading-relaxed text-foreground-muted md:text-sm">
      {disclaimerLead}
      <a
        href={lighthouseHref}
        class="font-medium text-brand-600 underline-offset-2 hover:underline dark:text-brand-400"
      >
        {lighthouseLinkLabel}
      </a>
      {disclaimerTrail}
    </p>
  </div>
</section>
