---
/** Shared logo strip styling for sales pillars (labels passed in from callers). */
import type { LogoKey } from '@/config/logoMarks';
import LogoChip from '@/components/ui/data-display/LogoChip/LogoChip.astro';

interface LogoItem {
  src: string;
  alt: string;
  logoKey?: LogoKey;
  wrapperClass?: string;
}

interface Props {
  ariaLabel: string;
  label: string;
  logos: LogoItem[];
}

const { ariaLabel, label, logos } = Astro.props;
---

<div class="pillar-stack mt-9 border-t border-border/60 pt-7 md:mt-10 md:pt-8" aria-label={ariaLabel}>
  <p class="mb-5 text-xs font-semibold uppercase tracking-wide text-foreground-muted md:mb-[1.125rem]">
    {label}
  </p>
  <ul class="m-0 flex list-none flex-wrap gap-3 p-0 sm:gap-4" role="list">
    {
      logos.map(({ src, alt, logoKey, wrapperClass }) => (
        <li class:list={[wrapperClass]}>
          <LogoChip src={src} alt={alt} logoKey={logoKey} width={96} height={24} />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .pillar-stack ul {
    align-items: center;
    justify-content: flex-start;
  }

  @media (min-width: 640px) {
    .pillar-stack ul {
      gap: 1rem;
    }
  }
</style>
