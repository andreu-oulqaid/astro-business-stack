---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n';
import astroLogo from '@/assets/external_logos/astro.svg';
import dockerLogo from '@/assets/external_logos/Docker-Logos-1/docker-logos/SVG/docker-mark-black.svg';
import githubActionsLogo from '@/assets/external_logos/githubactions-svgrepo-com.svg';
import decapLogo from '@/assets/external_logos/decap-cms.svg';
import hetznerLogo from '@/assets/external_logos/hetzner.svg';
import tailwindLogo from '@/assets/external_logos/tailwind-svgrepo-com.svg';
import supabaseLogo from '@/assets/external_logos/supabase-logo-icon.svg';
import notionLogo from '@/assets/external_logos/Notion-logo.svg';
import resendLogo from '@/assets/external_logos/resend-icon-black.svg';
import calLogo from '@/assets/external_logos/cal-com-light.svg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const logos = [
  { src: astroLogo.src, alt: 'Astro', darkFriendly: false },
  { src: dockerLogo.src, alt: 'Docker', darkFriendly: true },
  { src: githubActionsLogo.src, alt: 'GitHub Actions', darkFriendly: false },
  { src: decapLogo.src, alt: 'Decap CMS', darkFriendly: false },
  { src: hetznerLogo.src, alt: 'Hetzner', darkFriendly: false },
  { src: tailwindLogo.src, alt: 'Tailwind CSS', darkFriendly: false },
  { src: supabaseLogo.src, alt: 'Supabase', darkFriendly: false },
  { src: notionLogo.src, alt: 'Notion', darkFriendly: true },
  { src: resendLogo.src, alt: 'Resend', darkFriendly: true },
  { src: calLogo.src, alt: 'Cal.com', darkFriendly: false },
] as const;
---

<section class="trust-bar border-y border-border bg-background-secondary py-4" aria-label={t('trustBar.label')}>
  <div class="marquee-viewport">
    <div class="marquee-container">
      <div class="marquee-track">
        <div class="marquee-set">
          {
            logos.map((logo) => (
              <span class="marquee-item">
                <span class="logo-chip">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class:list={['logo-mark', logo.darkFriendly && 'logo-mark--dark-friendly']}
                    loading="lazy"
                    width="68"
                    height="18"
                  />
                </span>
              </span>
            ))
          }
        </div>
        <div class="marquee-set" aria-hidden="true">
          {
            logos.map((logo) => (
              <span class="marquee-item">
                <span class="logo-chip">
                  <img
                    src={logo.src}
                    alt=""
                    class:list={['logo-mark', logo.darkFriendly && 'logo-mark--dark-friendly']}
                    loading="lazy"
                    width="68"
                    height="18"
                  />
                </span>
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    --marquee-fade-start: 18%;
    --marquee-fade-end: 82%;
    --marquee-gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .trust-bar {
      --marquee-fade-start: 25%;
      --marquee-fade-end: 75%;
    }
  }

  .marquee-viewport {
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  .marquee-container {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 var(--marquee-fade-start),
      #000 var(--marquee-fade-end),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 var(--marquee-fade-start),
      #000 var(--marquee-fade-end),
      transparent 100%
    );
  }

  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    animation: marquee 38s linear infinite;
    will-change: transform;
  }

  .marquee-set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: var(--marquee-gap);
    /* Same spacing after the last logo as between logos — hides the loop seam */
    margin-right: var(--marquee-gap);
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
      will-change: auto;
    }

    .marquee-set {
      display: contents;
    }

    .marquee-set[aria-hidden='true'] {
      display: none;
    }
  }
</style>
