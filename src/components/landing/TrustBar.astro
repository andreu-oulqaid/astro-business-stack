---
import type { Locale } from '@/i18n/config';
import type { LogoKey } from '@/config/logoMarks';
import { useTranslations } from '@/i18n';
import LogoChip from '@/components/ui/data-display/LogoChip/LogoChip.astro';
import astroLogo from '@/assets/external_logos/astro.svg';
import dockerLogo from '@/assets/external_logos/Docker-Logos-1/docker-logos/SVG/docker-mark-black.svg';
import githubActionsLogo from '@/assets/external_logos/githubactions-svgrepo-com.svg';
import decapLogo from '@/assets/external_logos/decap-cms.svg';
import hetznerLogo from '@/assets/external_logos/hetzner.svg';
import tailwindLogo from '@/assets/external_logos/tailwind-svgrepo-com.svg';
import supabaseLogo from '@/assets/external_logos/supabase-logo-icon.svg';
import notionLogo from '@/assets/external_logos/Notion-logo.svg';
import resendLogo from '@/assets/external_logos/resend-icon-black.svg';
import calLogo from '@/assets/external_logos/cal-com-light.svg';
import velocityLogomark from '@/assets/external_logos/velocity/logomark.svg';
import velocityLogomarkDark from '@/assets/external_logos/velocity/logomark-dark.svg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const velocityUrl = 'https://github.com/southwellmedia/velocity';

const logos: { src: string; alt: string; key: LogoKey }[] = [
  { src: astroLogo.src, alt: 'Astro', key: 'astro' },
  { src: dockerLogo.src, alt: 'Docker', key: 'docker' },
  { src: githubActionsLogo.src, alt: 'GitHub Actions', key: 'githubActions' },
  { src: decapLogo.src, alt: 'Decap CMS', key: 'decap' },
  { src: hetznerLogo.src, alt: 'Hetzner', key: 'hetzner' },
  { src: tailwindLogo.src, alt: 'Tailwind CSS', key: 'tailwind' },
  { src: supabaseLogo.src, alt: 'Supabase', key: 'supabase' },
  { src: notionLogo.src, alt: 'Notion', key: 'notion' },
  { src: resendLogo.src, alt: 'Resend', key: 'resend' },
  { src: calLogo.src, alt: 'Cal.com', key: 'cal' },
];
---

<section class="trust-bar border-y border-border bg-background-secondary py-4" aria-label={t('trustBar.label')}>
  <div class="marquee-viewport">
    <div class="marquee-container">
      <div class="marquee-track">
        <div class="marquee-set">
          <a
            href={velocityUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="logo-chip marquee-item marquee-item--velocity"
            title={t('trustBar.velocityTitle')}
          >
            <img
              src={velocityLogomark.src}
              alt="Velocity"
              class="logo-mark logo-mark--velocity dark:hidden"
              loading="lazy"
              width="20"
              height="22"
            />
            <img
              src={velocityLogomarkDark.src}
              alt="Velocity"
              class="logo-mark logo-mark--velocity hidden dark:block"
              loading="lazy"
              width="20"
              height="22"
            />
          </a>
          {
            logos.map((logo) => (
              <span class="marquee-item">
                <LogoChip src={logo.src} alt={logo.alt} logoKey={logo.key} />
              </span>
            ))
          }
        </div>
        <div class="marquee-set" aria-hidden="true">
          <a
            href={velocityUrl}
            tabindex="-1"
            class="logo-chip marquee-item marquee-item--velocity"
          >
            <img
              src={velocityLogomark.src}
              alt=""
              class="logo-mark logo-mark--velocity dark:hidden"
              loading="lazy"
              width="20"
              height="22"
            />
            <img
              src={velocityLogomarkDark.src}
              alt=""
              class="logo-mark logo-mark--velocity hidden dark:block"
              loading="lazy"
              width="20"
              height="22"
            />
          </a>
          {
            logos.map((logo) => (
              <span class="marquee-item">
                <LogoChip src={logo.src} alt="" logoKey={logo.key} />
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <p class="trust-bar-attribution">
    {t('trustBar.attributionPrefix')}
    <a href={velocityUrl} target="_blank" rel="noopener noreferrer" class="trust-bar-attribution-link">
      {t('trustBar.attributionLink')}
    </a>
    {t('trustBar.attributionSuffix')}
  </p>
</section>

<style>
  .trust-bar {
    --marquee-fade-start: 18%;
    --marquee-fade-end: 82%;
    --marquee-gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .trust-bar {
      --marquee-fade-start: 25%;
      --marquee-fade-end: 75%;
    }
  }

  .marquee-viewport {
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  .marquee-container {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 var(--marquee-fade-start),
      #000 var(--marquee-fade-end),
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 var(--marquee-fade-start),
      #000 var(--marquee-fade-end),
      transparent 100%
    );
  }

  .marquee-track {
    display: flex;
    width: max-content;
    align-items: center;
    animation: marquee 38s linear infinite;
    will-change: transform;
  }

  .marquee-set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: var(--marquee-gap);
    margin-right: var(--marquee-gap);
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .marquee-item--velocity {
    text-decoration: none;
    color: inherit;
  }

  .trust-bar-attribution {
    margin: 0.625rem auto 0;
    max-width: 72rem;
    padding-inline: 1rem;
    text-align: center;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: var(--foreground-muted);
  }

  .trust-bar-attribution-link {
    font-weight: 600;
    color: var(--foreground-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--foreground-muted) 45%, transparent);
    text-underline-offset: 2px;
    transition: color 160ms ease;
  }

  .trust-bar-attribution-link:hover {
    color: var(--brand-500);
    text-decoration-color: color-mix(in oklab, var(--brand-500) 55%, transparent);
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
      will-change: auto;
    }

    .marquee-set {
      display: contents;
    }

    .marquee-set[aria-hidden='true'] {
      display: none;
    }
  }
</style>
