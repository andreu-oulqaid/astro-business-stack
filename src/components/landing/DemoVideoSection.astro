---
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const videoUrl = import.meta.env.PUBLIC_DEMO_VIDEO_URL as string | undefined;
const posterUrl = '/demo/tumbnail.png';
const posterAlt = t('demoVideo.posterAlt');

const isYoutube =
  videoUrl &&
  (videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be') || !videoUrl.includes('.mp4'));

function youtubeEmbedId(url: string): string | null {
  try {
    if (url.includes('youtu.be/')) return url.split('youtu.be/')[1]?.split(/[?&]/)[0] ?? null;
    if (url.includes('v=')) return new URL(url).searchParams.get('v');
    if (/^[a-zA-Z0-9_-]{11}$/.test(url)) return url;
  } catch {
    return null;
  }
  return null;
}

const youtubeId = videoUrl && isYoutube ? youtubeEmbedId(videoUrl) : null;
const hasVideo = Boolean(videoUrl && (youtubeId || videoUrl.endsWith('.mp4')));
---

<section id="demo" class="border-b border-border bg-background py-[var(--space-section-md)]" aria-labelledby="demo-video-heading">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <Badge variant="brand" size="sm" pill class="mb-4">
      {t('demoVideo.badge')}
    </Badge>
    <h2 id="demo-video-heading" class="font-display text-2xl font-bold tracking-tight text-foreground md:text-3xl">
      {t('demoVideo.title')}
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-foreground-muted md:text-base">
      {t('demoVideo.description')}
    </p>

    <div
      class="demo-video-frame group relative mt-8 aspect-video overflow-hidden rounded-xl border border-border bg-black shadow-[var(--theme-shadow-lg)]"
    >
      {
        hasVideo && youtubeId ? (
          <iframe
            class="absolute inset-0 h-full w-full"
            src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
            title={t('demoVideo.title')}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          />
        ) : hasVideo && videoUrl?.endsWith('.mp4') ? (
          <div class="demo-video-player relative h-full w-full" data-demo-video>
            <video
              class="demo-video h-full w-full object-cover"
              playsinline
              preload="metadata"
              poster={posterUrl}
              aria-label={t('demoVideo.title')}
            >
              <source src={videoUrl} type="video/mp4" />
            </video>
            <button
              type="button"
              class="demo-video-poster absolute inset-0 z-10 flex cursor-pointer items-center justify-center border-0 bg-transparent p-0"
              data-demo-video-poster
              aria-label={t('demoVideo.playLabel')}
            >
              <img
                src={posterUrl}
                alt={posterAlt}
                class="demo-video-poster-img absolute inset-0 h-full w-full object-cover"
                loading="eager"
                decoding="async"
              />
              <span class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/5 to-black/15" aria-hidden="true" />
              <span
                class="demo-video-play-btn relative flex h-16 w-16 items-center justify-center rounded-full border border-white/25 bg-black/45 text-white shadow-lg backdrop-blur-sm"
                aria-hidden="true"
              >
                <svg width="22" height="22" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M6 4l10 6-10 6V4z" />
                </svg>
              </span>
            </button>
          </div>
        ) : (
          <div class="relative flex h-full w-full items-center justify-center">
            <img
              src={posterUrl}
              alt={posterAlt}
              class="demo-video-poster-img absolute inset-0 h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-black/20" aria-hidden="true" />
            <div class="relative z-10 flex flex-col items-center gap-3 px-6">
              <span
                class="demo-video-play-btn flex h-16 w-16 items-center justify-center rounded-full border border-white/20 bg-black/40 text-white shadow-lg backdrop-blur-sm"
                aria-hidden="true"
              >
                <svg width="22" height="22" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M6 4l10 6-10 6V4z" />
                </svg>
              </span>
              <p class="text-sm font-medium text-white/90">{t('demoVideo.placeholder')}</p>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  import { trackInteraction } from '@/lib/trackInteraction';

  function initDemoVideoPlayers() {
    document.querySelectorAll<HTMLElement>('[data-demo-video]').forEach((root) => {
      if (root.dataset.demoVideoInit === 'true') return;
      root.dataset.demoVideoInit = 'true';

      const video = root.querySelector<HTMLVideoElement>('video');
      const poster = root.querySelector<HTMLButtonElement>('[data-demo-video-poster]');
      if (!video || !poster) return;

      const showPoster = () => {
        poster.hidden = false;
        video.removeAttribute('controls');
      };

      const hidePoster = () => {
        poster.hidden = true;
        video.setAttribute('controls', '');
      };

      poster.addEventListener('click', () => {
        trackInteraction({
          target: 'demo_video',
          placement: 'hero',
          action: 'play',
          category: 'media',
        });
        hidePoster();
        void video.play();
      });

      video.addEventListener('ended', () => {
        video.currentTime = 0;
        showPoster();
      });
    });
  }

  initDemoVideoPlayers();
  document.addEventListener('astro:page-load', initDemoVideoPlayers);
</script>

<style>
  .demo-video-frame {
    transition:
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 280ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 280ms ease;
  }

  .demo-video-frame:hover {
    transform: translateY(-3px);
    border-color: color-mix(in oklab, var(--brand-500) 22%, var(--border));
    box-shadow:
      0 20px 40px -24px color-mix(in oklab, var(--foreground) 28%, transparent),
      var(--theme-shadow-lg);
  }

  .demo-video-poster-img {
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .demo-video-frame:hover .demo-video-poster-img {
    transform: scale(1.03);
  }

  .demo-video-play-btn {
    transition:
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 200ms ease,
      border-color 200ms ease;
  }

  .demo-video-frame:hover .demo-video-play-btn {
    transform: scale(1.08);
    background-color: color-mix(in oklab, var(--brand-500) 55%, black);
    border-color: color-mix(in oklab, var(--brand-500) 40%, white);
  }

  .demo-video-poster:focus-visible {
    outline: none;
  }

  .demo-video-poster:focus-visible .demo-video-play-btn {
    outline: 2px solid var(--brand-500);
    outline-offset: 3px;
  }

  .demo-video-poster[hidden] {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-video-frame,
    .demo-video-frame:hover {
      transform: none;
    }

    .demo-video-poster-img,
    .demo-video-frame:hover .demo-video-poster-img,
    .demo-video-play-btn,
    .demo-video-frame:hover .demo-video-play-btn {
      transform: none;
      transition: none;
    }
  }
</style>
