---
import type { Locale } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import astroLogo from '@/assets/external_logos/astro.svg';
import tailwindLogo from '@/assets/external_logos/tailwind-svgrepo-com.svg';
import dockerLogo from '@/assets/external_logos/Docker-Logos-1/docker-logos/SVG/docker-mark-black.svg';
import githubActionsLogo from '@/assets/external_logos/githubactions-svgrepo-com.svg';
import notionLogo from '@/assets/external_logos/Notion-logo.svg';
import supabaseLogo from '@/assets/external_logos/supabase-logo-icon.svg';
import resendLogo from '@/assets/external_logos/resend-icon-black.svg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const portfolioBase = getLocalizedPath('portfolio', locale);

const metrics = [
  { label: t('techEdge.metrics.ssr'), value: t('techEdge.metrics.ssrValue') },
  { label: t('techEdge.metrics.locales'), value: t('techEdge.metrics.localesValue') },
  { label: t('techEdge.metrics.containers'), value: t('techEdge.metrics.containersValue') },
];
---

<section id="tech-edge" class="border-y border-border bg-background py-[var(--space-section-lg)]">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="mb-8 max-w-4xl text-balance font-display text-3xl font-bold tracking-tight text-foreground md:text-4xl">
      {t('techEdge.title')}
    </h2>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:items-stretch">
      <article class="flex h-full flex-col rounded-xl border border-border bg-background-secondary p-6">
        <h3 class="font-display text-xl font-semibold text-foreground">{t('techEdge.web.title')}</h3>
        <p
          class="mt-3 max-w-[42ch] text-sm leading-relaxed text-foreground-muted md:text-base"
          set:html={t('techEdge.web.body')}
        />

        <div class="mt-4 flex flex-wrap gap-2">
          {metrics.map((m) => (
            <Badge variant="default" size="sm">
              {m.label}: <span class="font-semibold text-foreground">{m.value}</span>
            </Badge>
          ))}
        </div>

        <div class="mt-5 flex flex-wrap items-center gap-2" aria-label="Web technology logos">
          <span class="logo-chip">
            <img src={astroLogo.src} alt="Astro" class="logo-mark" loading="lazy" />
          </span>
          <span class="logo-chip">
            <img src={tailwindLogo.src} alt="Tailwind CSS" class="logo-mark" loading="lazy" />
          </span>
        </div>

        <a
          href={`${portfolioBase}/multi-locale-ssr`}
          class="tech-link mt-5 inline-flex min-h-11 items-center gap-1.5 text-sm lg:mt-auto"
        >
          {t('techEdge.web.cta')}
          <Icon name="arrow-right" size="sm" />
        </a>
      </article>

      <div class="flex h-full flex-col gap-4">
        <article class="flex flex-1 flex-col rounded-xl border border-border bg-background-secondary p-6">
          <h3 class="font-display text-xl font-semibold text-foreground">{t('techEdge.automation.title')}</h3>
          <p
            class="mt-3 max-w-[42ch] text-sm leading-relaxed text-foreground-muted md:text-base"
            set:html={t('techEdge.automation.body')}
          />

          <div class="mt-5 flex flex-wrap items-center gap-2" aria-label="Deploy technology logos">
            <span class="logo-chip">
              <img src={dockerLogo.src} alt="Docker" class="logo-mark logo-mark--dark-friendly" loading="lazy" />
            </span>
            <span class="logo-chip">
              <img src={githubActionsLogo.src} alt="GitHub Actions" class="logo-mark" loading="lazy" />
            </span>
          </div>

          <a
            href={`${portfolioBase}/cms-workflow`}
            class="tech-link mt-5 inline-flex min-h-11 items-center gap-1.5 text-sm lg:mt-auto"
          >
            {t('techEdge.automation.cta')}
            <Icon name="arrow-right" size="sm" />
          </a>
        </article>

        <article class="flex flex-1 flex-col rounded-xl border border-border bg-background-secondary p-5">
          <h3 class="font-display text-base font-semibold text-foreground">{t('techEdge.bridge.title')}</h3>
          <p class="mt-2 text-sm leading-relaxed text-foreground-muted">
            {t('techEdge.bridge.body')}
          </p>

          <div class="mt-4 flex flex-wrap items-center gap-2" aria-label="Integration logos">
            <span class="logo-chip">
              <img src={notionLogo.src} alt="Notion" class="logo-mark logo-mark--dark-friendly" loading="lazy" />
            </span>
            <span class="logo-chip">
              <img src={supabaseLogo.src} alt="Supabase" class="logo-mark" loading="lazy" />
            </span>
            <span class="logo-chip">
              <img src={resendLogo.src} alt="Resend" class="logo-mark logo-mark--dark-friendly" loading="lazy" />
            </span>
          </div>

          <a
            href={`${portfolioBase}/lead-funnel`}
            class="tech-link mt-3 inline-flex min-h-11 items-center gap-1.5 text-sm lg:mt-auto"
          >
            {t('techEdge.bridge.cta')}
            <Icon name="arrow-right" size="sm" />
          </a>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .tech-link {
    color: var(--foreground-muted);
    font-weight: 500;
    transition: color 160ms ease;
  }

  .tech-link:hover {
    color: var(--brand-500);
  }
</style>
