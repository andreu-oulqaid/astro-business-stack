---
import type { Locale } from '@/i18n/config';
import { useTranslations, type TranslationKey } from '@/i18n';
import PillarTechStrip from '@/components/landing/PillarTechStrip.astro';
import n8nLogo from '@/assets/external_logos/N8n-logo-new.svg';
import claudeLogo from '@/assets/external_logos/Claude_AI_logo.svg';
import resendLogo from '@/assets/external_logos/resend-icon-black.svg';
import hetznerLogo from '@/assets/external_logos/hetzner.svg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<PillarTechStrip
  ariaLabel={t('salesAutomation.stackStripAria' as TranslationKey)}
  label={t('salesAutomation.stackStripLabel' as TranslationKey)}
  logos={[
    { src: n8nLogo.src, alt: 'n8n', logoKey: 'n8n' },
    { src: claudeLogo.src, alt: 'Claude', logoKey: 'claude' },
    { src: resendLogo.src, alt: 'Resend', logoKey: 'resend' },
    { src: hetznerLogo.src, alt: 'Hetzner', logoKey: 'hetzner' },
  ]}
/>
