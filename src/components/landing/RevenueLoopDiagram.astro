---
interface Props {
  title: string;
  descriptionId: string;
  description: string;
  steps: string[];
  note: string;
}

const { title, descriptionId, description, steps, note } = Astro.props;
const headingId = `${descriptionId}-heading`;
---

<section class="border-border border-y bg-background-secondary py-14 md:py-18" aria-labelledby={headingId}>
  <div class="mx-auto max-w-6xl px-6">
    <h2 id={headingId} class="font-display mb-4 text-center text-2xl font-bold text-foreground md:text-3xl">
      {title}
    </h2>
    <p id={descriptionId} class="mx-auto mb-10 max-w-2xl text-center text-foreground-muted">
      {description}
    </p>
    <ol
      class="mx-auto grid max-w-3xl gap-4 md:grid-cols-3"
      aria-describedby={descriptionId}
    >
      {
        steps.map((step, index) => (
          <li class="relative rounded-xl border border-border bg-background p-5 shadow-sm">
            <span class="mb-2 inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-500/15 text-sm font-bold text-brand-600 dark:text-brand-400">
              {index + 1}
            </span>
            <p class="text-sm leading-relaxed text-foreground">{step}</p>
            {index < steps.length - 1 && (
              <span class="pointer-events-none absolute -right-2 top-1/2 hidden h-0.5 w-4 -translate-y-1/2 bg-border md:block" aria-hidden="true" />
            )}
          </li>
        ))
      }
    </ol>
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-foreground-muted">{note}</p>
  </div>
</section>
