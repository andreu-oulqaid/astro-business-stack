---
/**
 * CTA Component (i18n-aware)
 * Reusable call-to-action section with translations and variants
 *
 * Variants:
 * - variant: 'default' | 'invert' (color scheme)
 * - size: 'sm' | 'md' | 'lg' | 'xl' (padding)
 * - align: 'center' | 'left' (content alignment)
 *
 * Features:
 * - Translations support
 * - Heading with highlight
 * - Optional logo
 * - Slot-based customization
 */
import type { HTMLAttributes } from 'astro/types';
import CtaBookingFunnel from '@/components/landing/CtaBookingFunnel';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { cn } from '@/lib/cn';
import { type Locale, getLocaleFromPath } from '@/i18n/config';
import { getCalLink } from '@/i18n/calLink';
import { getLocalizedPath, useTranslations } from '@/i18n/index';

interface Props extends HTMLAttributes<'section'> {
  /** Locale for translations */
  locale?: Locale;
  /** Color scheme variant */
  variant?: 'default' | 'invert';
  /** Padding size */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** Max width of content */
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl';
  /** `links` = GitHub + docs; `funnel` = booking lead capture */
  layout?: 'links' | 'funnel';
}

const {
  locale: localeProp,
  variant = 'default',
  size = 'lg',
  maxWidth = 'lg',
  layout = 'funnel',
  id = 'cta',
  class: className,
  ...attrs
} = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const isInvert = variant === 'invert';

const sectionStyles = {
  default: 'bg-background',
  invert: 'bg-surface-invert',
};

const headingStyles = {
  default: 'text-foreground',
  invert: 'text-on-invert',
};

const descriptionStyles = {
  default: 'text-foreground-muted',
  invert: 'text-on-invert-secondary',
};

const highlightStyles = {
  default: 'text-brand-500',
  invert: 'text-brand-400',
};

const sizes = {
  sm: 'py-[var(--space-section-sm)]',
  md: 'py-[var(--space-section-md)]',
  lg: 'py-[var(--space-section-lg)]',
  xl: 'py-[var(--space-section-xl)]',
};

const maxWidths = {
  sm: 'max-w-xl',
  md: 'max-w-2xl',
  lg: 'max-w-3xl',
  xl: 'max-w-4xl',
};

// Use translations for default content
const displayHeading = t('cta.title');
const displayHighlight = t('cta.titleHighlight');
const displayDescription = t('cta.description');
const calLink = getCalLink(locale);
const docsLink = `${siteConfig.github.url}#readme`;
const repoLink = siteConfig.github.url;
const privacyPath = getLocalizedPath('privacy', locale);
const funnelLabels = {
  step1Title: t('cta.funnel.step1Title'),
  nameLabel: t('cta.funnel.nameLabel'),
  namePlaceholder: t('cta.funnel.namePlaceholder'),
  step2Title: t('cta.funnel.step2Title'),
  emailLabel: t('cta.funnel.emailLabel'),
  emailPlaceholder: t('cta.funnel.emailPlaceholder'),
  phoneLabel: t('cta.funnel.phoneLabel'),
  phoneOptional: t('cta.funnel.phoneOptional'),
  phonePlaceholder: t('cta.funnel.phonePlaceholder'),
  honeypotLabel: t('cta.funnel.honeypotLabel'),
  next: t('cta.funnel.next'),
  back: t('cta.funnel.back'),
  step3Title: t('cta.funnel.step3Title'),
  leadError: t('cta.funnel.leadError'),
  nameError: t('cta.funnel.nameError'),
  emailError: t('cta.funnel.emailError'),
  savingHint: t('cta.funnel.savingHint'),
};

// Process heading with highlight
function processHeading(text: string, highlight?: string): string {
  if (!highlight) return text;
  return text.replace(highlight, `<span class="${highlightStyles[variant]}">${highlight}</span>`);
}

const hasHeadingSlot = Astro.slots.has('heading');
const hasDescriptionSlot = Astro.slots.has('description');
const hasActionsSlot = Astro.slots.has('actions');
const hasBookingFootnoteSlot = Astro.slots.has('booking-footnote');
---

<section
  id={id}
  class={cn(sectionStyles[variant], sizes[size], className)}
  {...attrs}
>
  <div class="mx-auto max-w-6xl px-6">
    <div class={cn(maxWidths[maxWidth], 'text-center mx-auto')}>
      {/* Heading Slot */}
      {hasHeadingSlot ? (
        <div class={cn(
          'mb-(--space-heading-gap)',
          '[&>h2]:font-display [&>h2]:text-3xl md:[&>h2]:text-4xl lg:[&>h2]:text-5xl [&>h2]:font-bold [&>h2]:text-balance',
          isInvert ? '[&>h2]:text-on-invert' : '[&>h2]:text-foreground'
        )}>
          <slot name="heading" />
        </div>
      ) : (
        <h2
          class={cn(
            'font-display text-3xl md:text-4xl lg:text-5xl font-bold text-balance mb-(--space-heading-gap)',
            headingStyles[variant]
          )}
          set:html={processHeading(displayHeading, displayHighlight)}
        />
      )}

      {/* Description Slot */}
      {hasDescriptionSlot ? (
        <div class={cn(
          'text-lg md:text-xl mb-(--space-stack-lg)',
          '[&>p]:text-lg md:[&>p]:text-xl',
          isInvert ? 'text-on-invert-secondary [&>p]:text-on-invert-secondary' : 'text-foreground-muted [&>p]:text-foreground-muted'
        )}>
          <slot name="description" />
        </div>
      ) : (
        <p class={cn('text-lg md:text-xl mb-(--space-stack-lg)', descriptionStyles[variant])}>
          <span set:html={displayDescription} />
        </p>
      )}

      {/* Actions Slot */}
      {hasActionsSlot ? (
        <div class="flex flex-col gap-4 sm:flex-row items-center justify-center">
          <slot name="actions" />
        </div>
      ) : layout === 'links' ? (
        <div class="flex flex-col gap-3 sm:flex-row items-center justify-center">
          <Button size="lg" href={repoLink}>
            <Icon name="github" size="sm" />
            <span set:html={t('cta.command')} />
          </Button>
          <Button size="lg" variant="outline" href={docsLink}>
            {t('cta.docs')}
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      ) : (
        <div class="mx-auto w-full max-w-xl">
          <CtaBookingFunnel client:visible calLink={calLink} labels={funnelLabels} locale={locale} />
        </div>
      )}

      {
        layout === 'funnel' && (
          <div
            class={cn(
              'mt-4 text-sm md:text-[0.9375rem] leading-relaxed',
              isInvert
                ? 'text-on-invert-secondary [&>p]:text-on-invert-secondary [&_a]:text-brand-300'
                : 'text-foreground-muted [&_a]:text-brand-600 dark:[&_a]:text-brand-400',
              '[&_a]:font-medium [&_a]:underline [&_a]:underline-offset-4'
            )}
          >
            {hasBookingFootnoteSlot ? (
              <slot name="booking-footnote" />
            ) : (
              <p>
                {t('cta.privacyNotePrefix')}{' '}
                <a href={privacyPath}>{t('cta.privacyNoteLink')}</a>{' '}
                {t('cta.privacyNoteSuffix')}
              </p>
            )}
          </div>
        )
      }

      <slot />
    </div>
  </div>
</section>

