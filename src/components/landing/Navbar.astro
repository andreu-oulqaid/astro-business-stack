---
/**
 * Navbar Component (i18n-aware)
 * Dynamic navigation with translations and language switcher
 */
import BrandMark from '@/components/ui/brand/BrandMark.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import ThemeToggle from '@/components/layout/ThemeToggle.astro';
import LanguageSwitcher from '@/components/i18n/LanguageSwitcher.astro';
import siteConfig from '@/config/site.config';
import { type Locale, defaultLocale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

// Check if we're on the landing page to determine link behavior
const currentPath = Astro.url.pathname;
const homePath = getLocalizedPath('home', locale);
const isLandingPage = currentPath === homePath || currentPath === `${homePath}/`;

const featuresLink = isLandingPage ? '#tech-edge' : `${homePath}#tech-edge`;
const deploymentsLink = isLandingPage ? '#deployments' : `${homePath}#deployments`;
const faqLink = isLandingPage ? '#faq' : `${homePath}#faq`;
const githubLink = siteConfig.github.url;
const linkedinLink = siteConfig.linkedin.url;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Logo -->
    <a href={homePath} class="flex items-center gap-2.5">
      <BrandMark />
      <span class="font-display text-lg font-bold tracking-tight text-foreground">{t('site.name')}</span>
    </a>

    <!-- Desktop Menu -->
    <div class="hidden flex-1 items-center justify-end gap-8 md:flex">
      <a href={featuresLink} class="text-sm font-medium text-foreground-muted hover:text-foreground transition-colors">
        {t('nav.features')}
      </a>
      <a href={deploymentsLink} class="text-sm font-medium text-foreground-muted hover:text-foreground transition-colors">
        {t('nav.portfolio')}
      </a>
      <a href={faqLink} class="text-sm font-medium text-foreground-muted hover:text-foreground transition-colors">
        {t('nav.faq')}
      </a>
      <a
        href={linkedinLink}
        class="text-sm font-medium text-foreground-muted hover:text-foreground transition-colors"
        target="_blank"
        rel="noopener noreferrer"
        data-analytics-target="linkedin"
        data-analytics-placement="navbar"
        data-analytics-action="click"
      >
        {t('nav.contact')}
      </a>

      <div class="flex items-center gap-2 border-l border-border pl-6">
        <LanguageSwitcher />
        <ThemeToggle />
        <Button
          size="sm"
          href={githubLink}
          data-analytics-target="github"
          data-analytics-placement="navbar"
          data-analytics-action="click"
        >
          <Icon name="github" size="sm" />
          <span set:html={t('nav.getStarted')} />
        </Button>
      </div>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <Button
        size="sm"
        href={githubLink}
        class="h-9 px-3 text-xs"
        data-analytics-target="github"
        data-analytics-placement="navbar"
        data-analytics-action="click"
      >
        <Icon name="github" size="sm" />
        <span set:html={t('nav.getStarted')} />
      </Button>

      <!-- Mobile Toggle -->
      <button
        type="button"
        class="p-2 text-foreground hover:bg-secondary rounded-md transition-colors"
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="menu-icon">
          <Icon name="menu" size="lg" />
        </span>
        <span class="close-icon hidden">
          <Icon name="x" size="lg" />
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden absolute top-16 left-0 w-full bg-background border-b border-border p-6 md:hidden flex-col gap-4 shadow-lg">
    <a href={featuresLink} class="text-base font-medium text-foreground-secondary hover:text-foreground transition-colors">
      {t('nav.features')}
    </a>
    <a href={deploymentsLink} class="text-base font-medium text-foreground-secondary hover:text-foreground transition-colors">
      {t('nav.portfolio')}
    </a>
    <a href={faqLink} class="text-base font-medium text-foreground-secondary hover:text-foreground transition-colors">
      {t('nav.faq')}
    </a>
    <a
      href={linkedinLink}
      class="text-base font-medium text-foreground-secondary hover:text-foreground transition-colors"
      target="_blank"
      rel="noopener noreferrer"
      data-analytics-target="linkedin"
      data-analytics-placement="navbar"
      data-analytics-action="click"
    >
      {t('nav.contact')}
    </a>

    <div class="flex items-center gap-3 pt-2 border-t border-border">
      <LanguageSwitcher />
      <ThemeToggle />
    </div>
    <Button
      fullWidth
      href={githubLink}
      data-analytics-target="github"
      data-analytics-placement="navbar"
      data-analytics-action="click"
    >
      <Icon name="github" size="sm" />
      <span set:html={t('nav.getStarted')} />
    </Button>
  </div>
</nav>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = toggle?.querySelector('.menu-icon');
    const closeIcon = toggle?.querySelector('.close-icon');
    const navRoot = toggle?.closest('nav');

    if (!toggle || !menu || !menuIcon || !closeIcon || !navRoot) return;
    if (toggle.dataset.mobileMenuBound === '1') return;
    toggle.dataset.mobileMenuBound = '1';

    const closeMenu = () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      menuIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      menuIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    };

    const isMenuOpen = () => !menu.classList.contains('hidden');

    toggle.addEventListener('click', () => {
      if (isMenuOpen()) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close menu when clicking on links
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    // Close mobile menu when clicking outside the navbar/menu area.
    document.addEventListener('click', (event) => {
      if (!isMenuOpen()) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!navRoot.contains(target)) {
        closeMenu();
      }
    });

    // Close with Escape for better mobile keyboard accessibility.
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isMenuOpen()) {
        closeMenu();
      }
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>

<style>
  .nav-services-dropdown summary::-webkit-details-marker {
    display: none;
  }
</style>
