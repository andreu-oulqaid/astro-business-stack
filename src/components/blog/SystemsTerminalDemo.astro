---
/**
 * “Full stack” demo terminal (blog.servicesTerminal copy) — reused on hub + pillar heroes.
 */
import type { Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';
import { TerminalDemo, type ScriptLine } from '@/components/ui/marketing/TerminalDemo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const d = {
  fast: 260,
  normal: 430,
  afterProcessingCommand: 900,
  afterResultsHeader: 850,
  afterFinalStatus: 1200,
} as const;

const script: ScriptLine[] = [
  { text: t('blog.servicesTerminal.line1'), delay: d.normal, type: 'system-command' },
  { text: t('blog.servicesTerminal.line2'), delay: d.fast, type: 'result-line' },
  { text: t('blog.servicesTerminal.line3'), delay: d.normal, type: 'ok-line' },
  { text: t('blog.servicesTerminal.line4'), delay: d.normal, type: 'ok-line' },
  { text: t('blog.servicesTerminal.line5'), delay: d.fast, type: 'result-line' },
  { text: t('blog.servicesTerminal.line6'), delay: d.afterProcessingCommand, type: 'system-command' },
  { text: t('blog.servicesTerminal.line7'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line8'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line9'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line10'), delay: d.fast, type: 'result-line' },
  { text: t('blog.servicesTerminal.line11'), delay: d.afterResultsHeader, type: 'system-command' },
  { text: t('blog.servicesTerminal.line12'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line13'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line14'), delay: d.normal, type: 'info-line' },
  { text: t('blog.servicesTerminal.line15'), delay: d.afterFinalStatus, type: 'status-line' },
];
---

<TerminalDemo
  client:visible
  script={script}
  chromeLabel={t('blog.servicesTerminal.chromeLabel')}
  contentClassName="min-h-[220px] h-[260px] sm:h-[300px] md:min-h-[260px] md:h-[320px] overflow-y-auto p-4 font-mono"
  restartDelayMs={5200}
/>
